    "def combine_2rd_columns(col_1, col_2):\n",
    "    result = col_1\n",
    "    if not pd.isna(col_2):\n",
    "        result += \" \" + str(col_2)\n",
    "    return result\n",
    "\n",
    "\n",
    "# data = pd.read_csv(\"pilot_textming.csv\")\n",
    "data[\"text\"] = data.apply(lambda x: combine_2rd_columns(x['Title'], x['Abstract']), axis=1)\n",
    "\n",
    "df = data.loc[:, ['text']]\n",
    "df.tail()"
   ]
