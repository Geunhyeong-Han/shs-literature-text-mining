   "source": [
    "# 키워드들의 TF-IDF 벡터를 가져옵니다.\n",
    "selected_keywords_list = list(selected_keywords)\n",
    "selected_keyword_indices = [np.where(feature_names == keyword)[0][0] for keyword in selected_keywords_list]\n",
    "selected_tfidf_vectors = tfidf_matrix[:, selected_keyword_indices].toarray()\n",
    "\n",
    "# GMM 클러스터링을 수행합니다. \n",
    "n_clusters = 100 # 임의로 설정한 클러스터 개수\n",
    "gmm = GaussianMixture(n_components=n_clusters)\n",
    "gmm.fit(selected_tfidf_vectors)\n",
    "\n",
    "# 각 클러스터에 속하는 단어들의 리스트를 생성합니다.\n",
    "clusters = [[] for _ in range(n_clusters)]\n",
    "labels = gmm.predict(selected_tfidf_vectors)\n",
    "for word, label in zip(selected_keywords_list, labels):\n",
    "    clusters[label].append(word)\n",
    "\n",
    "# 10번의 클러스터링 분석을 수행하고, 일관되게 중요하지 않다고 판단되는 단어들을 추출합니다.\n",
    "non_important_words_sets = []\n",
    "for _ in range(10):\n",
    "    gmm.fit(selected_tfidf_vectors)\n",
    "    labels = gmm.predict(selected_tfidf_vectors)\n",
    "    \n",
    "    # 가장 큰 클러스터를 '중요하지 않은' 단어들로 간주합니다.\n",
    "    largest_cluster_label = np.bincount(labels).argmax()\n",
    "    non_important_words_sets.append(set(word for i, word in enumerate(selected_keywords_list) if labels[i] != largest_cluster_label))\n",
    "\n",
    "# 모든 실행에서 공통적으로 중요하지 않다고 판단된 단어들만 추출합니다.\n",
    "common_non_important_words_set = set.intersection(*non_important_words_sets)\n",
    "\n",
    "print(\"Common Non-Important Words:\")\n",
    "for word in common_non_important_words_set:\n",
    "    print(word)\n",
    "\n",
    "# 선택된 키워드 목록에서 공통적으로 중요하지 않은 단어들을 제거합니다.\n",
    "final_selected_keywords_set = set(selected_keywords_list) - common_non_important_words_set\n",
    "\n",
    "print(\"\\nFinal Selected Keywords:\")\n",
    "for word in final_selected_keywords_set:\n",
    "    print(word)"
   ]
  },
