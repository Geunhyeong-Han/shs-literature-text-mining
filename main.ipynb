    "# 상위 Docuement 당 TF-IDF 기반 상위 4개의 단어 추출 함수 정의\n",
    "\n",
    "top_keywords_per_document = []\n",
    "feature_names = tfidf_vectorizer.get_feature_names_out()\n",
    "\n",
    "for i in range(len(df)):\n",
    "    tfidf_scores = zip(feature_names, tfidf_matrix[i].toarray()[0])\n",
    "    sorted_tfidf_scores = sorted(tfidf_scores,key=lambda x: x[1], reverse=True)\n",
    "    top_keywords_per_document.append([keyword for keyword,_ in sorted_tfidf_scores[:4]])\n",
    "\n",
    "# 전체 데이터셋에서 적어도 2번 이상 나온 키워드 추출하기 \n",
    "all_keywords=[keyword for document in top_keywords_per_document for keyword in document]\n",
    "selected_keywords=list(set(keyword for keyword in all_keywords if all_keywords.count(keyword) >=2))\n",
    "\n",
    "# 선택된 키워드를 기반으로 Document-Term Matrix 생성\n",
    "vectorizer=CountVectorizer(vocabulary=selected_keywords)\n",
    "document_term_matrix=vectorizer.fit_transform(df['processed_text'])\n",
    "\n",
    "# WordCloud 시각화 함수 정의 및 실행   \n",
    "def visualize_wordcloud(keywords):\n",
    "     wordcloud=WordCloud(background_color='white', width=800,height=400).generate(' '.join(keywords))\n",
    "     plt.imshow(wordcloud.recolor(colormap='viridis',random_state=42),interpolation=\"bilinear\")\n",
    "     plt.axis(\"off\")\n",
    "     plt.show()\n",
    "\n",
    "visualize_wordcloud(selected_keywords)\n",
    "document_term_matrix"
   ]
