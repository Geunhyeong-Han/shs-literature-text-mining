    "# 1. TF-IDF 값을 다시 계산합니다.\n",
    "vectorizer = TfidfVectorizer(vocabulary=final_selected_keywords_set)\n",
    "tfidf_matrix = vectorizer.fit_transform(df[\"processed_text\"])\n",
    "\n",
    "# 2. 각 데이터 항목(문서) 간의 코사인 유사도를 계산합니다.\n",
    "cosine_sim_matrix = cosine_similarity(tfidf_matrix)\n",
    "\n",
    "# 3. 코사인 유사도가 특정 임곗값보다 높은(즉, 문서들이 매우 비슷한) 데이터 항목들을 제거합니다.\n",
    "threshold = 0.8  # 임곗값 설정\n",
    "outlier_indices = []\n",
    "\n",
    "for i in range(len(df)):\n",
    "    for j in range(i+1, len(df)):\n",
    "        if cosine_sim_matrix[i][j] > threshold:\n",
    "            outlier_indices.append(j)\n",
    "\n",
    "# 중복된 인덱스 제거\n",
    "outlier_indices = list(set(outlier_indices))\n",
    "\n",
    "# 이상치 아닌 문서만 선택하여 최종 문서 집합 생성\n",
    "final_documents = [doc for i, doc in enumerate(df[\"processed_text\"]) if i not in outlier_indices]"
   ]
