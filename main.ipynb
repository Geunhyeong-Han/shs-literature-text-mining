    "from sklearn.decomposition import PCA\n",
    "from sklearn.cluster import SpectralClustering\n",
    "from sklearn.metrics import silhouette_score, pairwise_distances\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 선택된 키워드에 대한 TF-IDF 벡터 생성 및 PCA로 차원 축소 (2차원)\n",
    "vectorizer = TfidfVectorizer(vocabulary=final_selected_keywords_set)\n",
    "tfidf_matrix_selected_keywords = vectorizer.fit_transform(final_documents)\n",
    "pca_model = PCA(n_components=2)\n",
    "pca_result = pca_model.fit_transform(tfidf_matrix_selected_keywords.toarray())\n",
    "\n",
    "# 클러스터 개수 범위 설정 (2부터 50까지)\n",
    "cluster_range = range(2, 51)\n",
    "\n",
    "# 각 클러스터 개수별로 Silhouette 평균 값을 기록할 리스트 초기화\n",
    "silhouette_scores_cosine = []\n",
    "silhouette_scores_euclidean = []\n",
    "\n",
    "# PCA 결과를 기반으로 Spectral Clustering 및 Silhouette 계수 측정 반복\n",
    "for n_clusters in cluster_range:\n",
    "    silhouette_scores_per_cluster_cosine = []\n",
    "    silhouette_scores_per_cluster_euclidean = []\n",
    "    \n",
    "    for _ in range(10):  # 10번 반복하여 평균값 구함\n",
    "        # Spectral Clustering 모델 생성 및 학습 (코사인 유사도 기반)\n",
    "        clustering_model_cosine = SpectralClustering(n_clusters=n_clusters, affinity='nearest_neighbors')\n",
    "        cluster_labels_cosine = clustering_model_cosine.fit_predict(pca_result)\n",
    "\n",
    "        # 거리 행렬 계산 (유클리디안 거리 기반)\n",
    "        distance_matrix_euclidean = pairwise_distances(pca_result, metric='euclidean')\n",
    "\n",
    "        # Spectral Clustering 모델 생성 및 학습 (유클리디안 거리 기반)\n",
    "        clustering_model_euclidean = SpectralClustering(n_clusters=n_clusters, affinity='precomputed')\n",
    "        cluster_labels_euclidean = clustering_model_euclidean.fit_predict(distance_matrix_euclidean)\n",
    "\n",
    "        # Silhouette 계수 측정 및 기록 (코사인 유사도와 유클리디안 거리 두 가지 방법으로 각각 수행)\n",
    "        silhouette_avg_cosine = silhouette_score(pca_result, cluster_labels_cosine) \n",
    "        silhouette_avg_euclidean= silhouette_score(distance_matrix_euclidean , cluster_labels_euclidean)\n",
    "        \n",
    "        silhouette_scores_per_cluster_cosine.append(silhouette_avg_cosine)\n",
    "        silhouette_scores_per_cluster_euclidean.append(silhouette_avg_euclidean)\n",
    "\n",
    "    # 각 클러스터 개수별로 Silhoutte 평균 값의 평균을 구함 (코사인 유사도)\n",
    "    avg_silhouette_score_cosine= np.mean(silhouette_scores_per_cluster_cosine)\n",
    "    silhouette_scores_cosine.append(avg_silhouette_score_cosine)\n",
    "\n",
    "    # 각 클러스터 개수별로 Silhoutte 평균 값의 평균을 구함 (유클리디안 거리)  \n",
    "    avg_silhoutte_score_Eucildean= np.mean(silhouette_scores_per_cluster_euclidean)\n",
    "    silhouette_scores_euclidean.append(avg_silhoutte_score_Eucildean)\n",
    "\n",
    "\n",
    "# 클러스터 개수에 따른 Silhoutte 평균 값 시각화 (코사인 유사도)\n",
    "plt.plot(cluster_range,silhouette_scores_cosine, marker='o', label='Cosine Similarity')\n",
    "plt.xlabel('Number of Clusters')\n",
    "plt.ylabel('Average Silloute Score ')\n",
    "plt.title('Silloute Score vs Number of Clusters - Cosine Similarity')\n",
    "\n",
    "# 클러스터 개수에 따른 Silloute Average 점 수 시각화(유클라이드 거리) \n",
    "plt.plot(cluster_range,silhouette_scores_euclidean, marker='o', label='Euclidian Distance ')\n",
    "plt.xlabel('Number of Clusters')\n",
    "plt.ylabel('Average Silloute Score ')\n",
    "plt.title('Silloute Score vs Number of Cluster - Euclidian Distance ')\n",
    "\n",
    "# 범례 추가 \n",
    "plt.legend()\n",
    "\n",
    "# 그래프 출력\n",
    "plt.show()"
   ]
  },
